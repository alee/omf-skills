{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Evaluation Schema",
  "description": "Schema for evaluating agent skill routing, behavior, outputs, and boundary conditions.",
  "type": "object",
  "required": [
    "schema_version",
    "evals"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the eval schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "skill_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "suite": {
      "type": "string"
    },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "prompt",
          "should_trigger"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "core",
              "adversarial",
              "cross",
              "cross-adversarial"
            ]
          },
          "prompt": {
            "type": "string",
            "minLength": 5
          },
          "should_trigger": {
            "type": "boolean",
            "description": "Whether the skill under evaluation should activate for this prompt."
          },
          "routing_target": {
            "type": "string",
            "description": "Expected target skill or subsystem for routing decisions."
          },
          "behavior": {
            "type": "array",
            "description": "Observable process-level assertions: routing decisions, skill invocations, and actions taken before output is produced.",
            "items": {
              "type": "string"
            }
          },
          "output": {
            "type": "object",
            "description": "Expected response-level properties.",
            "properties": {
              "description": {
                "type": "string"
              },
              "must_include": {
                "type": "array",
                "description": "Terms, concepts, or behaviors that must appear in the response.",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "must_not_include": {
                "type": "array",
                "description": "Terms, concepts, or behaviors that must not appear in the response.",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            },
            "required": [
              "description",
              "must_include",
              "must_not_include"
            ],
            "additionalProperties": false
          },
          "success_criteria": {
            "type": "array",
            "description": "Evaluable conditions spanning both process and output, used when checkable assertions alone are insufficient.",
            "items": {
              "type": "string"
            }
          },
          "skills_expected": {
            "type": "array",
            "description": "Skills expected to participate in routing or orchestration.",
            "items": {
              "type": "string"
            }
          },
          "failure_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "over_trigger",
                "under_trigger",
                "wrong_skill",
                "wrong_order",
                "scope_creep",
                "hallucination",
                "keyword_trap",
                "boundary_violation",
                "incomplete_execution",
                "missing_step",
                "missing_evidence",
                "insufficient_uncertainty",
                "invalid_output",
                "invalid_publication_claim",
                "no_planning",
                "redundant_actions"
              ]
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "enum": [
                    "adversarial",
                    "cross-adversarial"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "failure_modes"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "enum": [
                    "cross",
                    "cross-adversarial"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "skills_expected"
              ]
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
